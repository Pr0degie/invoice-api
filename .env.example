# ── Database ──────────────────────────────────────────────────────────────────
# Railway injects DATABASE_URL automatically when a Postgres service is linked.
# Alternatively set the Npgsql connection string directly:
DATABASE_URL=postgres://user:pass@host:5432/invoiceapi
# ConnectionStrings__Default=Host=...;Port=5432;Database=invoiceapi;Username=...;Password=...

# ── JWT ───────────────────────────────────────────────────────────────────────
Jwt__SigningKey=<generate with: openssl rand -base64 48>
Jwt__Issuer=invoice-api
Jwt__Audience=invoiceflow
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=30

# ── CORS ──────────────────────────────────────────────────────────────────────
# Exact origins allowed. Vercel preview URLs (invoiceflow-*.vercel.app) are
# whitelisted via code pattern — no wildcard entry needed here.
Cors__AllowedOrigins__0=https://invoiceflow.yourdomain.com

# ── Seed ──────────────────────────────────────────────────────────────────────
# Set to true on first deploy to populate demo user + invoices.
# Safe to leave enabled — only runs when the users table is empty.
Seed__Enabled=true

# ── ASP.NET Core ──────────────────────────────────────────────────────────────
ASPNETCORE_URLS=http://0.0.0.0:8080
ASPNETCORE_ENVIRONMENT=Production

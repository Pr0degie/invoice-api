{
  "ConnectionStrings": {
    "Default": "Host=localhost;Database=invoiceapi;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "invoice-api",
    "Audience": "invoiceflow",
    "SigningKey": "CHANGE_ME_IN_PRODUCTION_min_32_chars_long",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
